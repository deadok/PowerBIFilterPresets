{
  "name": "power-bi-filter-presets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release:check-tag": "node --experimental-strip-types scripts/release/cli.ts check-tag",
    "release:verify-source": "node --experimental-strip-types scripts/release/cli.ts verify-source",
    "release:verify-built": "node --experimental-strip-types scripts/release/cli.ts verify-built",
    "release:build-zip": "node --experimental-strip-types scripts/release/cli.ts build-zip",
    "release:write-key": "node --experimental-strip-types scripts/release/cli.ts write-key",
    "release:sign-crx": "node --experimental-strip-types scripts/release/cli.ts sign-crx",
    "release:checksums": "node --experimental-strip-types scripts/release/cli.ts generate-checksums",
    "release:verify-checksums": "node --experimental-strip-types scripts/release/cli.ts verify-checksums",
    "release:inspect": "node --experimental-strip-types scripts/release/cli.ts inspect",
    "release:extension-id": "node --experimental-strip-types scripts/release/cli.ts extension-id"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^22.10.2",
    "@types/yauzl": "3.3.0",
    "@types/yazl": "3.3.1",
    "typescript": "^5.5.4",
    "crx3": "2.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.5",
    "jsdom": "^24.1.1",
    "yaml": "2.9.0",
    "yauzl": "3.4.0",
    "yazl": "3.3.1"
  }
}
