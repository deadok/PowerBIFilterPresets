{
  "manifest_version": 3,
  "name": "Power BI Filter Presets",
  "version": "0.1.0",
  "description": "Save and restore local presets for embedded Power BI list filters.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_title": "Power BI Presets",
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/contentScript.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
